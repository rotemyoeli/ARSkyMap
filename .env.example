# ---- Backend (Flask) ----
# DEV_MODE bypasses auth for pre-launch development. NEVER set true in production.
DEV_MODE=true
SECRET_KEY=change-me-in-production
# Railway injects DATABASE_URL automatically. Locally use the docker-compose Postgres:
DATABASE_URL=postgresql://arskymap:arskymap@localhost:5432/arskymap

# ---- Frontend (Vite) ----
VITE_API_BASE=http://localhost:8000/api
